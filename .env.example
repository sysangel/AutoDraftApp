# ============================================================
# Email Draft App — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

MAILBOX_EMAIL=you@yourdomain.com
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_USERNAME=you@yourdomain.com
MAILBOX_PASSWORD=your_actual_password
DRAFTS_FOLDER=Drafts
OPENAI_API_KEY=sk-...your key...
OPENAI_MODEL=gpt-4o-mini

# --- App ---
# SQLite database file path (relative to app directory)
DATABASE_URL=sqlite:///./email_drafts.db
